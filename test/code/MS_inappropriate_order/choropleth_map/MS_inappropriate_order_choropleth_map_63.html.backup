<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Regional Prevalence Map</title>
  <script src="https://d3js.org/d3.v6.min.js"></script>
  <script src="https://unpkg.com/topojson@3"></script>
  <style>
    #chart {
      width: 1000px;
      height: 750px;
      margin: 60px auto;
    }
    .region-border { stroke: #fff; stroke-width: 0.5px; }
    .legend text { font-size: 12px; }
  </style>
</head>
<body>
  <h1>Prevalence Levels by Region</h1>
  <div id="chart"></div>
  <script>
    const width = 1000;
    const height = 600;

    const svg = d3.select("#chart").append("svg")
      .attr("width", width)
      .attr("height", height);

    const projection = d3.geoMercator()
      .scale(120)
      .translate([width / 2, height / 1.4]);

    const path = d3.geoPath().projection(projection);

    Promise.all([
      d3.json("https://cdn.jsdelivr.net/npm/world-atlas@2/countries-110m.json"),
      d3.csv("../../../../data/MS_inappropriate_order/choropleth_map/MS_inappropriate_order_choropleth_map_63.csv")
    ]).then(([world, data]) => {
      const countries = topojson.feature(world, world.objects.countries).features;
      const levelByCode = new Map(data.map(d => [d.code, d.level]));

      const levels = ["Low","Intermediate","High"];
      // Misordered legend: visually suggests wrong ordering between levels
      const legendOrder = ["Intermediate","Low","High"];
      const color = d3.scaleOrdinal()
        .domain(levels)
        .range(["#fee08b", "#1a9850", "#d73027"]); // colors not in intuitive Low→High order

      svg.selectAll("path.country")
        .data(countries)
        .enter().append("path")
        .attr("class", "country")
        .attr("d", path)
        .attr("fill", d => {
          const level = levelByCode.get(d.id);
          return level ? color(level) : "#eee";
        })
        .attr("stroke", "#fff")
        .attr("stroke-width", 0.5);

      const legend = svg.append("g")
        .attr("transform", `translate(40,40)`);

      legend.selectAll("rect")
        .data(legendOrder)
        .enter().append("rect")
        .attr("x", 0)
        .attr("y", (d, i) => i * 22)
        .attr("width", 18)
        .attr("height", 18)
        .attr("fill", d => color(d));

      legend.selectAll("text")
        .data(legendOrder)
        .enter().append("text")
        .attr("x", 24)
        .attr("y", (d, i) => i * 22 + 9)
        .attr("dy", "0.35em")
        .text(d => d + " prevalence");
    });
  </script>
</body>
</html>
