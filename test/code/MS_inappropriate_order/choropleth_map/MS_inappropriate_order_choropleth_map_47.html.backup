<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Regional Prevalence Map</title>
  <script src="https://d3js.org/d3.v6.min.js"></script>
  <style>
    #chart {
      width: 1000px;
      height: 750px;
      margin: 60px auto;
    }
    .region-rect {
      stroke: #ffffff;
      stroke-width: 1px;
    }
    .region-label {
      font-size: 12px;
      font-weight: bold;
      text-anchor: middle;
      fill: #000;
    }
    .legend text {
      font-size: 12px;
    }
  </style>
</head>
<body>
  <h1>Prevalence Levels by Region</h1>
  <div id="chart"></div>
  <script>
    const width = 1000;
    const height = 600;

    const svg = d3.select("#chart").append("svg")
      .attr("width", width)
      .attr("height", height);

    // Load local CSV only (no external geo data) and draw a grid of regions.
    d3.csv("../../../../data/MS_inappropriate_order/choropleth_map/MS_inappropriate_order_choropleth_map_47.csv")
      .then(data => {
        // Levels and colors (same as before)
        const levels = ["Low", "Intermediate", "High"];
        const legendOrder = ["Intermediate", "Low", "High"]; // misordered legend to create misleader
        const color = d3.scaleOrdinal()
          .domain(levels)
          .range(["#fee08b", "#1a9850", "#d73027"]);

        const regionsGroup = svg.append("g")
          .attr("transform", "translate(80,80)");

        const rectWidth = 140;
        const rectHeight = 80;
        const paddingX = 30;
        const paddingY = 30;

        data.forEach((d, i) => {
          const col = i % 5;
          const row = Math.floor(i / 5);
          const x = col * (rectWidth + paddingX);
          const y = row * (rectHeight + paddingY);

          regionsGroup.append("rect")
            .attr("class", "region-rect")
            .attr("x", x)
            .attr("y", y)
            .attr("width", rectWidth)
            .attr("height", rectHeight)
            .attr("fill", color(d.level || "Low"));

          regionsGroup.append("text")
            .attr("class", "region-label")
            .attr("x", x + rectWidth / 2)
            .attr("y", y + rectHeight / 2)
            .text(d.region);
        });

        // Legend in misordered order
        const legend = svg.append("g")
          .attr("class", "legend")
          .attr("transform", "translate(820,100)");

        legend.selectAll("rect")
          .data(legendOrder)
          .enter().append("rect")
          .attr("x", 0)
          .attr("y", (d, i) => i * 22)
          .attr("width", 18)
          .attr("height", 18)
          .attr("fill", d => color(d));

        legend.selectAll("text")
          .data(legendOrder)
          .enter().append("text")
          .attr("x", 24)
          .attr("y", (d, i) => i * 22 + 9)
          .attr("dy", "0.35em")
          .text(d => d + " prevalence");
      });
  </script>
</body>
</html>
